---
import '../styles/global.css';
import { site, asset } from '../data/site';

// One page, one layout. Everything SEO-facing is centralised here so the
// markup below stays about content.
const title = `${site.name} — ${site.tagline}`;
const canonical = site.url;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Mark JS as available before paint so scroll-reveal can hide content
         without risking a blank page when JS is off. -->
    <script is:inline>document.documentElement.classList.add('js');</script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={site.description} />
    <meta name="author" content={site.name} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#faf7f0" />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={site.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={site.ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Divyanshu Kumar — business operator who can build. ₹100Cr+ MSME deal flow, 1st IIT Roorkee, UN Millennium Fellow." />
    <meta property="og:locale" content={site.locale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={site.description} />
    <meta name="twitter:image" content={site.ogImage} />

    <!-- Favicon: a serif "D" drawn inline so there are zero extra requests -->
    <link
      rel="icon"
      href={`data:image/svg+xml,${encodeURIComponent(
        `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='14' fill='#faf7f0'/><text x='50' y='73' font-family='Georgia,serif' font-size='68' font-weight='600' text-anchor='middle' fill='#9e2b25'>D</text></svg>`
      )}`}
    />
    <link rel="apple-touch-icon" href={asset('images/apple-touch-icon-180.png')} />
    <link rel="manifest" href={asset('manifest.json')} />

    <!-- Structured data: this page is a person's profile -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ProfilePage',
      mainEntity: {
        '@type': 'Person',
        name: site.name,
        url: site.url,
        image: site.ogImage,
        jobTitle: 'Credit Operations & AI — Finance',
        alumniOf: { '@type': 'CollegeOrUniversity', name: 'CHRIST (Deemed to be University)' },
        knowsAbout: ['Credit Assessment', 'MSME Lending Operations', 'Financial Modelling', 'Anomaly Detection', 'NLP', 'Pricing & GTM Strategy'],
        sameAs: ['https://github.com/NovaXTritan', 'https://www.linkedin.com/in/divyanshukumar27'],
      },
    })} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />

    <!--
      Retire any service worker registered by the previous version of this site.
      The old build shipped a caching SW; without this, returning visitors
      (e.g. a recruiter who opened the link before) could be served stale HTML.
    -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.getRegistrations?.().then((rs) => rs.forEach((r) => r.unregister()));
        if (window.caches?.keys) caches.keys().then((ks) => ks.forEach((k) => caches.delete(k)));
      }
    </script>

    <!-- Quiet fade-up on scroll. Pure CSS classes toggled by an observer. -->
    <script is:inline>
      (() => {
        const items = document.querySelectorAll('.reveal');
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) {
          items.forEach((el) => el.classList.add('in'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        items.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
