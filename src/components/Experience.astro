---
// Most important section. Ledger rows, metrics in the prose. Mirrors the résumé.
const roles = [
  {
    role: 'Credit Operations & AI',
    org: 'Rajesh Credit Consultancy',
    meta: 'Noida · 2023 – Present',
    points: [
      'Run the loan desk for a 25-year MSME lending firm across <strong>15 bank partners</strong> (SIDBI, SBI, ICICI, PNB, Kotak). Cumulative deal value past <strong>₹100Cr</strong>, approvals at <strong>65–75%</strong> against an industry norm near 35–40%.',
      'Read borrower books (P&amp;L, balance sheet, cash flow) and structure files to clear debt-service ratios across manufacturing, trading, and services.',
      'Built the team’s tracking stack myself — pipeline dashboard, bank-relationship database, qualification scorecards. <strong>Twelve people use it daily.</strong>',
    ],
  },
  {
    role: 'Strategy & AI Transformation Intern',
    org: 'Kingdom 24 Pvt. Ltd.',
    meta: 'Delhi NCR · Apr – Jul 2026',
    points: [
      'Took the firm’s financial diagnostic end to end and shipped its production site (<strong>Next.js, 526 pages</strong>) to back diligence on a PNB credit line.',
      'Wrote two data pipelines that stuck: one mapping APMC mandi prices to <strong>₹53Cr of procurement</strong>, another assembling a <strong>13,422-restaurant</strong> NCR dataset from FSSAI and Google Places.',
      'Replaced a paid chatbot SaaS with one I built on FastAPI (English, Hindi, Hinglish) — <strong>dropped that recurring cost to zero</strong>.',
    ],
  },
  {
    role: 'Management Consulting Intern',
    org: 'S.K. Chadha & Associates',
    meta: 'May – Jun 2025',
    points: [
      'For <strong>boAt</strong>, scraped Amazon and Flipkart into an automated review tracker and ran <strong>20+ mystery audits</strong> across retail channels.',
      'For <strong>AMS Healthcare</strong>, rebuilt CPAP/BiPAP pricing off 200+ quotes; quote turnaround dropped about <strong>35%</strong>.',
    ],
  },
];
---

<section class="section" id="work">
  <div class="wrap">
    <p class="kicker reveal">Selected Experience</p>
    <h2 class="section-title reveal">Where the numbers come from.</h2>

    <ol class="exp-list">
      {roles.map((r, i) => (
        <li class="exp-row reveal">
          <span class="exp-num">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <div class="exp-head">
              <h3 class="exp-role">{r.role} <span class="exp-org">· {r.org}</span></h3>
              <span class="exp-meta">{r.meta}</span>
            </div>
            <ul class="exp-points">
              {r.points.map((p) => <li set:html={p} />)}
            </ul>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
