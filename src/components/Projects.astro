---
// Featured ventures. Each live product links out.
const projects = [
  {
    name: 'FinSight India',
    tag: '1st · IIT Roorkee',
    blurb:
      'Market-intelligence platform built around the information gap retail investors face against institutions. A <strong>Composite Anomaly Score</strong> over five signals, backtested on <strong>1,046 signals</strong> across the Nifty 50 — caught a live ICICIBANK move at a <strong>3.18 Z-score</strong>. <strong>1st place, IIT Roorkee Cognizance IDEAZ 2026.</strong>',
    stack: ['Python', 'NLP', 'Firebase'],
    href: 'https://finsight-nova.web.app',
    hrefLabel: 'finsight-nova.web.app',
    wide: false,
  },
  {
    name: 'Sustainmetric',
    tag: 'Live',
    blurb:
      'Geospatial AI for urban climate &amp; BRSR compliance. Pulls Sentinel-2, OpenAQ, Open-Meteo, ERA5 and OSM data through Gemini to produce <strong>audit-grade urban-heat intervention plans</strong>. Targets the BRSR Core mandate for the top 1,000 listed firms.',
    stack: ['Gemini', 'Sentinel-2', 'Geospatial', 'Python'],
    href: 'https://sustainmetric.web.app',
    hrefLabel: 'sustainmetric.web.app',
    wide: false,
  },
  {
    name: 'Cosmos',
    sub: 'AI peer-accountability platform',
    tag: 'UN Fellow · 72% WoW',
    blurb:
      'A peer-accountability platform with an AI journal. <strong>UN Millennium Fellowship — top 4%</strong> of roughly 60,000 applicants, with retention holding at <strong>72% week over week</strong>.',
    stack: ['React', 'Firebase', 'Gemini API'],
    href: 'https://cosmos-nova.web.app',
    hrefLabel: 'cosmos-nova.web.app',
    wide: true,
  },
];
---

<section class="section" id="projects">
  <div class="wrap">
    <p class="kicker reveal">Ventures &amp; Projects</p>
    <h2 class="section-title reveal">Things I shipped, with links.</h2>

    <div class="proj-grid">
      {projects.map((p) => (
        <article class={`proj-card reveal${p.wide ? ' wide' : ''}`}>
          <div class="proj-top">
            <h3 class="proj-name">
              {p.name}
              {p.sub && <span class="proj-note"> — {p.sub}</span>}
            </h3>
            <span class="proj-tag">{p.tag}</span>
          </div>

          <p class="proj-blurb" set:html={p.blurb} />

          <div class="proj-stack">
            {p.stack.map((s) => <span>{s}</span>)}
          </div>

          <a class="proj-link" href={p.href} target="_blank" rel="noopener">
            View live <span class="arrow">↗</span>
            <span class="sr-only">{p.hrefLabel}</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
