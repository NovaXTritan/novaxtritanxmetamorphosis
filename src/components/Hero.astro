---
import { contact, asset } from '../data/site';
---

<header class="hero wrap" id="top">
  <div class="hero-grid">
    <div class="hero-copy reveal">
      <p class="hero-eyebrow">BBA (Hons) Finance &amp; Marketing Analytics · CHRIST University · Noida · 2024–2027</p>

      <h1 class="hero-title">Business operator<br />who can <span class="accent">build.</span></h1>

      <div class="hero-rule" aria-hidden="true"></div>

      <p class="hero-summary">
        I run the loan desk at a 25-year MSME lending firm — <strong>₹100Cr+</strong> in cumulative deal
        value across <strong>15 bank partners</strong>, approvals at <strong>65–75%</strong> against a
        35–40% industry norm. Then I build the software around the operation: a production diligence site,
        data pipelines, and market-intelligence platforms.
      </p>

      <!-- three figures that should land before anyone reads a sentence -->
      <dl class="hero-figures">
        <div class="figure">
          <dt class="figure-num">₹100Cr+</dt>
          <dd class="figure-label">Cumulative MSME deal value</dd>
        </div>
        <div class="figure">
          <dt class="figure-num">1st</dt>
          <dd class="figure-label">IIT Roorkee Cognizance IDEAZ 2026</dd>
        </div>
        <div class="figure">
          <dt class="figure-num">Top 4%</dt>
          <dd class="figure-label">UN Millennium Fellowship (~60,000)</dd>
        </div>
      </dl>

      <div class="hero-actions">
        <a class="btn-primary" href={asset(contact.resume)} target="_blank" rel="noopener">
          Download Résumé (PDF)
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" />
          </svg>
        </a>
        <div class="hero-inline-links">
          <a href={`mailto:${contact.email}`}>Email</a>
          <a href={contact.linkedin} target="_blank" rel="noopener">LinkedIn</a>
          <a href={contact.github} target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </div>

    <figure class="hero-portrait reveal">
      <img
        src={asset('images/1745733549930.jpg')}
        alt="Portrait of Divyanshu Kumar"
        width="600"
        height="600"
        loading="eager"
        decoding="async"
      />
      <figcaption>Noida · ’27</figcaption>
    </figure>
  </div>
</header>
