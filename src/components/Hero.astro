---
import { contact, asset } from '../data/site';
---

<header class="hero wrap" id="top">
  <div class="hero-grid">
    <div class="hero-copy reveal">
      <p class="hero-eyebrow">BBA Finance &amp; Marketing Analytics · Christ University · Delhi NCR · 2024–2027</p>

      <h1 class="hero-title">Business operator<br />who can <span class="accent">build.</span></h1>

      <div class="hero-rule" aria-hidden="true"></div>

      <p class="hero-summary">
        I run real operations and ship AI products. A management-consulting stint that surfaced
        <strong>₹45L+ in cost savings</strong>, and a 25-year-old family MSME loan consultancy moving
        <strong>₹600+ crore</strong> in cumulative deal flow. Econometric research, taken to production software.
      </p>

      <!-- three figures that should land before anyone reads a sentence -->
      <dl class="hero-figures">
        <div class="figure">
          <dt class="figure-num">₹600cr+</dt>
          <dd class="figure-label">Cumulative MSME deal flow</dd>
        </div>
        <div class="figure">
          <dt class="figure-num">₹45L+</dt>
          <dd class="figure-label">Cost savings identified in consulting</dd>
        </div>
        <div class="figure">
          <dt class="figure-num">1st</dt>
          <dd class="figure-label">IIT Roorkee Cognizance IDEAZ 2026</dd>
        </div>
      </dl>

      <div class="hero-actions">
        <a class="btn-primary" href={asset(contact.resume)} target="_blank" rel="noopener">
          Download Résumé (PDF)
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" />
          </svg>
        </a>
        <div class="hero-inline-links">
          <a href={`mailto:${contact.email}`}>Email</a>
          <a href={contact.linkedin} target="_blank" rel="noopener">LinkedIn</a>
          <a href={contact.github} target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </div>

    <figure class="hero-portrait reveal">
      <img
        src={asset('images/1745733549930.jpg')}
        alt="Portrait of Divyanshu Kumar"
        width="600"
        height="600"
        loading="eager"
        decoding="async"
      />
      <figcaption>Delhi NCR · ’27</figcaption>
    </figure>
  </div>
</header>
