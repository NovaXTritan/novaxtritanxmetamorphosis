---
import { contact, asset } from '../data/site';

const channels = [
  { label: 'Email', value: contact.email, href: `mailto:${contact.email}`, external: false },
  { label: 'LinkedIn', value: contact.linkedinLabel, href: contact.linkedin, external: true },
  { label: 'GitHub', value: contact.githubLabel, href: contact.github, external: true },
  { label: 'Résumé', value: 'Download (PDF)', href: asset(contact.resume), external: true },
];
---

<section class="section" id="contact">
  <div class="wrap">
    <div class="contact-grid">
      <div class="reveal">
        <p class="kicker">Contact</p>
        <h2 class="contact-title">Let’s talk.</h2>
        <p class="contact-lede">
          BBA student at CHRIST University, Noida — available for Summer 2027 internships.
          If you’re working on credit, strategy, or AI in finance, I’d like to hear from you.
        </p>
      </div>

      <div class="contact-list reveal">
        {channels.map((c) => (
          <a href={c.href} target={c.external ? '_blank' : undefined} rel={c.external ? 'noopener' : undefined}>
            <span class="contact-channel">{c.label}</span>
            <span class="contact-value">{c.value} {c.external && '↗'}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
