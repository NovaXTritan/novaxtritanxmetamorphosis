---
// Research & leadership. The Rajya Sabha committee leads deliberately.
const leadership = [
  {
    title: 'Youth Advisory Committee — office of Rajya Sabha MP Shri Surendra Singh Nagar',
    sub: 'One of three open-seat members on an eight-person committee, picked through a region-wide process.',
    lead: true,
  },
  {
    title: 'Student Council Representative',
    sub: 'Elected for the cohort of 450+; carried welfare issues to the administration and spoke at institutional forums.',
  },
  {
    title: 'Office Bearer, Finance & AI Cell',
    sub: 'Youngest office bearer university-wide. Ran financial-literacy sessions and the IIT Delhi eDC partnership.',
  },
];

const distinctions = [
  {
    title: 'Two research papers accepted — IIT Madras (IndustriAI 2025, PAN IIT 2026)',
    sub: 'A multi-agent system for MSME loan decisions · NLP detecting cognitive bias across 818 SEC filings.',
  },
  {
    title: 'UN Millennium Fellowship — Top 4%',
    sub: 'Of roughly 60,000 applicants globally.',
  },
  {
    title: '3rd place, Eco-Sankalp 3.0 — SSCBS, University of Delhi',
    sub: 'Pitching Sustainmetric.',
  },
  {
    title: 'National finalist — SRCC business-plan competition',
    sub: 'Top 9 of 560 teams.',
  },
];

const certs = [
  'Strategy & Game Theory — IIM Ahmedabad',
  'Bloomberg Market Concepts',
  'Google Data Analytics',
  'Advanced Excel',
];
---

<section class="section" id="about">
  <div class="wrap">
    <p class="kicker reveal">Research &amp; Leadership</p>
    <h2 class="section-title reveal">Outside the day job.</h2>

    <div class="rec-grid">
      <div class="rec-col reveal">
        <h3>Leadership</h3>
        <ul class="rec-list">
          {leadership.map((it) => (
            <li class={it.lead ? 'lead-item' : ''}>
              <span class="rec-item-title">
                {it.lead && <span class="star">★ </span>}{it.title}
              </span>
              {it.sub && <span class="rec-item-sub">{it.sub}</span>}
            </li>
          ))}
        </ul>
      </div>

      <div class="rec-col reveal">
        <h3>Research &amp; Distinctions</h3>
        <ul class="rec-list">
          {distinctions.map((it) => (
            <li>
              <span class="rec-item-title">{it.title}</span>
              {it.sub && <span class="rec-item-sub">{it.sub}</span>}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="certs reveal">
      <span class="certs-label">Certifications</span>
      {certs.map((c) => <span>{c}</span>)}
    </div>
  </div>
</section>
