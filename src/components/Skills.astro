---
const technical = [
  'Python (pandas, NumPy, scikit-learn)', 'SQL', 'Next.js / React', 'FastAPI',
  'Firebase', 'PostgreSQL', 'Power BI', 'Tableau', 'Excel (VBA)', 'NLP',
];
const business = [
  'Credit assessment', 'MSME lending operations', 'Financial modelling',
  'Anomaly detection', 'Pricing & GTM strategy',
];
---

<section class="section" id="skills">
  <div class="wrap">
    <p class="kicker reveal">Capabilities</p>
    <h2 class="section-title reveal">What I work with.</h2>

    <div class="skills-grid">
      <div class="skills-col reveal">
        <h3>Technical</h3>
        <div class="skills-tags">{technical.map((s) => <span>{s}</span>)}</div>
      </div>
      <div class="skills-col reveal">
        <h3>Business</h3>
        <div class="skills-tags">{business.map((s) => <span>{s}</span>)}</div>
      </div>
    </div>
  </div>
</section>
